      "outcomesModule": {
        "primaryOutcomes": [
          {
            "measure": "Mean change in modified Mayo Score (mMs) from Baseline to Week 12",
            "description": "The mMS is an endoscopic and clinical scale, which ranges in scores from 0-9, with higher numbers indicating increased disease severity. It is used to assess UC disease activity. It consists of three subscores: RBS, SFS and an endoscopy subscore.",
            "timeFrame": "Baseline to Week 12"
          }
        ],
        "secondaryOutcomes": [
          {
            "measure": "Proportion of subjects achieving clinical remission at Week 12",
            "description": "Defined as a mMS ≤ 2, with a stool frequency subscore (SFS) ≤ 1, RBS=0, and endoscopic subscore ≤ 1 without friability.",
            "timeFrame": "Baseline to Week 12"
          },
          {
            "measure": "Proportion of subjects showing endoscopic treatment improvement at Week 12",
            "description": "Defined as an endoscopy subscore ≤ 1 without friability.",
            "timeFrame": "Baseline to Week 12"
          },
          {
            "measure": "Proportion of subjects achieving a clinical response at Week 12",
            "description": "Defined as a decrease from Baseline in mMS ≥ 2 points and ≥ 30% with a decrease from Baseline in RBS ≥ 1 point or an absolute RBS ≤ 1.",
            "timeFrame": "Baseline to Week 12"
          }
        ]
      },
      "eligibilityModule": {
        "eligibilityCriteria": "Inclusion Criteria:\n\n* Male or female ≥18\n* Participants with a clinical diagnosis of UC for prior to Day 1\n* Subject has moderate to severe, active UC, defined as a mMS ≥ 5 with an endoscopy subscore ≥2\n* Subject has had a surveillance colonoscopy that did not detect potential dysplasia or colon cancer performed within 1 year of Day 1.\n* Subject has a history of an inadequate response, loss of response, or intolerance to any combination of at least 2 UC therapy classes defined as, but not limited to, aminosalicylates, corticosteroids, immunomodulators, calcineurin inhibitors, or advanced UC therapies (e.g., biologics, JAK inhibitors, oral S1P receptor modulators, etc.)\n\nExclusion Criteria:\n\n* Subject has a diagnosis of Crohn's disease or indeterminate colitis.\n* Subject has a diagnosis of fulminant colitis and/or toxic megacolon.\n* Subject has a history of an inadequate response, loss of response, or intolerance to any combination of 3 or more advanced UC therapy classes but not limited to, 1) anti-TNF antibodies (e.g., adalimumab, golimumab, infliximab), 2) other biologics (e.g., ustekinumab, vedolizumab), 3) oral JAK inhibitors (e.g., tofacitinib, upadacitinib), and 4) oral S1P receptor modulators (e.g., ozanimod).\n* Subject has disease limited to the rectum (ulcerative proctitis)\n* Subject has a history of colectomy (total or subtotal), ileoanal pouch, Kock pouch, or ileostomy or is planning bowel surgery.\n* The subject had prior exposure to a PD-1 or PD-L1 agonist, antagonist, or modulator.",
        "healthyVolunteers": false,
        "sex": "ALL",
        "minimumAge": "18 Years",
        "stdAges": [
          "ADULT",
          "OLDER_ADULT"
        ]
      },
